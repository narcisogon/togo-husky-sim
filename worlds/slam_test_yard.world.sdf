<?xml version="1.0" ?>
<sdf version="1.9">
  <world name="enhanced_lunar_test">
    <physics name="fast_stable" type="ignored">
      <max_step_size>0.004</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre</render_engine>
    </plugin>
    <plugin filename="gz-sim-imu-system" name="gz::sim::systems::Imu"/>

    <gravity>0 0 -9.81</gravity>

    <scene>
      <ambient>0.35 0.35 0.36 1</ambient>
      <background>0.03 0.035 0.045 1</background>
      <grid>true</grid>
      <shadows>true</shadows>
    </scene>

    <light type="directional" name="low_sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 70 0 0 0</pose>
      <diffuse>0.78 0.76 0.72 1</diffuse>
      <specular>0.08 0.08 0.08 1</specular>
      <intensity>2.6</intensity>
      <direction>-0.55 0.25 -0.80</direction>
    </light>

    <model name="flat_lunar_test_floor">
      <static>true</static>
      <link name="floor_link">
        <collision name="floor_collision">
          <geometry>
            <box>
              <size>80 80 0.10</size>
            </box>
          </geometry>
        </collision>
        <visual name="floor_visual">
          <geometry>
            <box>
              <size>80 80 0.10</size>
            </box>
          </geometry>
          <material>
            <ambient>0.28 0.28 0.27 1</ambient>
            <diffuse>0.40 0.39 0.36 1</diffuse>
            <specular>0.015 0.015 0.015 1</specular>
          </material>
        </visual>
      </link>
      <pose>0 0 -0.05 0 0 0</pose>
    </model>

    <!-- Near-spawn asymmetric landmarks. These keep the first local map
         observable for point-to-plane scan matching instead of relying on
         distant parallel outer walls. -->
    <model name="spawn_landmark_wall_a">
      <static>true</static>
      <pose>6.5 3.0 1.0 0 0 0.45</pose>
      <link name="wall_link">
        <collision name="collision"><geometry><box><size>4.0 0.30 2.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>4.0 0.30 2.0</size></box></geometry>
          <material><ambient>0.34 0.36 0.38 1</ambient><diffuse>0.56 0.59 0.62 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="spawn_landmark_wall_b">
      <static>true</static>
      <pose>-5.0 4.5 0.8 0 0 -0.85</pose>
      <link name="wall_link">
        <collision name="collision"><geometry><box><size>3.2 0.28 1.6</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>3.2 0.28 1.6</size></box></geometry>
          <material><ambient>0.36 0.34 0.31 1</ambient><diffuse>0.58 0.53 0.45 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="spawn_landmark_box_a">
      <static>true</static>
      <pose>3.5 -5.5 0.65 0 0 0.2</pose>
      <link name="box_link">
        <collision name="collision"><geometry><box><size>2.2 1.4 1.3</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>2.2 1.4 1.3</size></box></geometry>
          <material><ambient>0.28 0.31 0.24 1</ambient><diffuse>0.44 0.51 0.38 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="spawn_landmark_box_b">
      <static>true</static>
      <pose>-7.0 -3.5 0.50 0 0 1.1</pose>
      <link name="box_link">
        <collision name="collision"><geometry><box><size>1.5 1.0 1.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>1.5 1.0 1.0</size></box></geometry>
          <material><ambient>0.33 0.25 0.25 1</ambient><diffuse>0.55 0.39 0.37 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="spawn_pole_a"><static>true</static><pose>5.0 -2.0 1.25 0 0 0</pose><link name="pole_link"><collision name="collision"><geometry><cylinder><radius>0.14</radius><length>2.5</length></cylinder></geometry></collision><visual name="visual"><geometry><cylinder><radius>0.14</radius><length>2.5</length></cylinder></geometry><material><ambient>0.45 0.45 0.42 1</ambient><diffuse>0.75 0.75 0.70 1</diffuse></material></visual></link></model>
    <model name="spawn_pole_b"><static>true</static><pose>-3.5 -6.0 1.25 0 0 0</pose><link name="pole_link"><collision name="collision"><geometry><cylinder><radius>0.14</radius><length>2.5</length></cylinder></geometry></collision><visual name="visual"><geometry><cylinder><radius>0.14</radius><length>2.5</length></cylinder></geometry><material><ambient>0.45 0.45 0.42 1</ambient><diffuse>0.75 0.75 0.70 1</diffuse></material></visual></link></model>
    <model name="spawn_pole_c"><static>true</static><pose>-1.5 7.0 1.25 0 0 0</pose><link name="pole_link"><collision name="collision"><geometry><cylinder><radius>0.14</radius><length>2.5</length></cylinder></geometry></collision><visual name="visual"><geometry><cylinder><radius>0.14</radius><length>2.5</length></cylinder></geometry><material><ambient>0.45 0.45 0.42 1</ambient><diffuse>0.75 0.75 0.70 1</diffuse></material></visual></link></model>

    <!-- Outer square walls: strong long-range constraints for LiDAR frontend testing. -->
    <model name="north_outer_wall">
      <static>true</static>
      <pose>0 40 1.5 0 0 0</pose>
      <link name="wall_link">
        <collision name="collision"><geometry><box><size>80 0.35 3.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>80 0.35 3.0</size></box></geometry>
          <material><ambient>0.36 0.38 0.37 1</ambient><diffuse>0.55 0.57 0.54 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="south_outer_wall">
      <static>true</static>
      <pose>0 -40 1.5 0 0 0</pose>
      <link name="wall_link">
        <collision name="collision"><geometry><box><size>80 0.35 3.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>80 0.35 3.0</size></box></geometry>
          <material><ambient>0.36 0.38 0.37 1</ambient><diffuse>0.55 0.57 0.54 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="east_outer_wall">
      <static>true</static>
      <pose>40 0 1.5 0 0 0</pose>
      <link name="wall_link">
        <collision name="collision"><geometry><box><size>0.35 80 3.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.35 80 3.0</size></box></geometry>
          <material><ambient>0.36 0.38 0.37 1</ambient><diffuse>0.55 0.57 0.54 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="west_outer_wall">
      <static>true</static>
      <pose>-40 0 1.5 0 0 0</pose>
      <link name="wall_link">
        <collision name="collision"><geometry><box><size>0.35 80 3.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.35 80 3.0</size></box></geometry>
          <material><ambient>0.36 0.38 0.37 1</ambient><diffuse>0.55 0.57 0.54 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Internal walls form corridors and occlusions without boxing in the spawn area. -->
    <model name="inner_wall_a">
      <static>true</static>
      <pose>-14 12 1.1 0 0 0.0</pose>
      <link name="wall_link">
        <collision name="collision"><geometry><box><size>20 0.30 2.2</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>20 0.30 2.2</size></box></geometry>
          <material><ambient>0.33 0.35 0.36 1</ambient><diffuse>0.48 0.51 0.52 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="inner_wall_b">
      <static>true</static>
      <pose>12 -8 1.1 0 0 1.5708</pose>
      <link name="wall_link">
        <collision name="collision"><geometry><box><size>18 0.30 2.2</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>18 0.30 2.2</size></box></geometry>
          <material><ambient>0.33 0.35 0.36 1</ambient><diffuse>0.48 0.51 0.52 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="inner_wall_c">
      <static>true</static>
      <pose>4 20 1.1 0 0 0.65</pose>
      <link name="wall_link">
        <collision name="collision"><geometry><box><size>14 0.30 2.2</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>14 0.30 2.2</size></box></geometry>
          <material><ambient>0.33 0.35 0.36 1</ambient><diffuse>0.48 0.51 0.52 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Container-like boxes: asymmetric rectangular features for scan matching. -->
    <model name="container_red_01">
      <static>true</static>
      <pose>-20 -18 1.3 0 0 0.25</pose>
      <link name="container_link">
        <collision name="collision"><geometry><box><size>8.0 2.5 2.6</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>8.0 2.5 2.6</size></box></geometry>
          <material><ambient>0.42 0.18 0.15 1</ambient><diffuse>0.68 0.28 0.22 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="container_blue_02">
      <static>true</static>
      <pose>20 17 1.3 0 0 -0.55</pose>
      <link name="container_link">
        <collision name="collision"><geometry><box><size>8.0 2.5 2.6</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>8.0 2.5 2.6</size></box></geometry>
          <material><ambient>0.14 0.24 0.36 1</ambient><diffuse>0.22 0.39 0.60 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="container_green_03">
      <static>true</static>
      <pose>24 -19 1.3 0 0 1.25</pose>
      <link name="container_link">
        <collision name="collision"><geometry><box><size>7.0 2.4 2.6</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>7.0 2.4 2.6</size></box></geometry>
          <material><ambient>0.16 0.32 0.22 1</ambient><diffuse>0.26 0.52 0.34 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Pole field: thin vertical landmarks help expose yaw and lateral drift issues. -->
    <model name="pole_01"><static>true</static><pose>-8 -4 1.5 0 0 0</pose><link name="pole_link"><collision name="collision"><geometry><cylinder><radius>0.18</radius><length>3.0</length></cylinder></geometry></collision><visual name="visual"><geometry><cylinder><radius>0.18</radius><length>3.0</length></cylinder></geometry><material><ambient>0.42 0.42 0.40 1</ambient><diffuse>0.72 0.72 0.68 1</diffuse></material></visual></link></model>
    <model name="pole_02"><static>true</static><pose>-3 6 1.5 0 0 0</pose><link name="pole_link"><collision name="collision"><geometry><cylinder><radius>0.18</radius><length>3.0</length></cylinder></geometry></collision><visual name="visual"><geometry><cylinder><radius>0.18</radius><length>3.0</length></cylinder></geometry><material><ambient>0.42 0.42 0.40 1</ambient><diffuse>0.72 0.72 0.68 1</diffuse></material></visual></link></model>
    <model name="pole_03"><static>true</static><pose>7 4 1.5 0 0 0</pose><link name="pole_link"><collision name="collision"><geometry><cylinder><radius>0.18</radius><length>3.0</length></cylinder></geometry></collision><visual name="visual"><geometry><cylinder><radius>0.18</radius><length>3.0</length></cylinder></geometry><material><ambient>0.42 0.42 0.40 1</ambient><diffuse>0.72 0.72 0.68 1</diffuse></material></visual></link></model>
    <model name="pole_04"><static>true</static><pose>14 7 1.5 0 0 0</pose><link name="pole_link"><collision name="collision"><geometry><cylinder><radius>0.18</radius><length>3.0</length></cylinder></geometry></collision><visual name="visual"><geometry><cylinder><radius>0.18</radius><length>3.0</length></cylinder></geometry><material><ambient>0.42 0.42 0.40 1</ambient><diffuse>0.72 0.72 0.68 1</diffuse></material></visual></link></model>
    <model name="pole_05"><static>true</static><pose>-16 23 1.5 0 0 0</pose><link name="pole_link"><collision name="collision"><geometry><cylinder><radius>0.18</radius><length>3.0</length></cylinder></geometry></collision><visual name="visual"><geometry><cylinder><radius>0.18</radius><length>3.0</length></cylinder></geometry><material><ambient>0.42 0.42 0.40 1</ambient><diffuse>0.72 0.72 0.68 1</diffuse></material></visual></link></model>
    <model name="pole_06"><static>true</static><pose>30 6 1.5 0 0 0</pose><link name="pole_link"><collision name="collision"><geometry><cylinder><radius>0.18</radius><length>3.0</length></cylinder></geometry></collision><visual name="visual"><geometry><cylinder><radius>0.18</radius><length>3.0</length></cylinder></geometry><material><ambient>0.42 0.42 0.40 1</ambient><diffuse>0.72 0.72 0.68 1</diffuse></material></visual></link></model>
    <model name="pole_07"><static>true</static><pose>-28 -2 1.5 0 0 0</pose><link name="pole_link"><collision name="collision"><geometry><cylinder><radius>0.18</radius><length>3.0</length></cylinder></geometry></collision><visual name="visual"><geometry><cylinder><radius>0.18</radius><length>3.0</length></cylinder></geometry><material><ambient>0.42 0.42 0.40 1</ambient><diffuse>0.72 0.72 0.68 1</diffuse></material></visual></link></model>
    <model name="pole_08"><static>true</static><pose>2 -27 1.5 0 0 0</pose><link name="pole_link"><collision name="collision"><geometry><cylinder><radius>0.18</radius><length>3.0</length></cylinder></geometry></collision><visual name="visual"><geometry><cylinder><radius>0.18</radius><length>3.0</length></cylinder></geometry><material><ambient>0.42 0.42 0.40 1</ambient><diffuse>0.72 0.72 0.68 1</diffuse></material></visual></link></model>

    <!-- Low blocks add near-field geometric texture without becoming impassable walls. -->
    <model name="low_block_01"><static>true</static><pose>-6 -18 0.35 0 0 0.4</pose><link name="block_link"><collision name="collision"><geometry><box><size>2.0 1.2 0.7</size></box></geometry></collision><visual name="visual"><geometry><box><size>2.0 1.2 0.7</size></box></geometry><material><ambient>0.31 0.30 0.28 1</ambient><diffuse>0.48 0.46 0.41 1</diffuse></material></visual></link></model>
    <model name="low_block_02"><static>true</static><pose>9 -23 0.45 0 0 -0.7</pose><link name="block_link"><collision name="collision"><geometry><box><size>2.8 1.6 0.9</size></box></geometry></collision><visual name="visual"><geometry><box><size>2.8 1.6 0.9</size></box></geometry><material><ambient>0.31 0.30 0.28 1</ambient><diffuse>0.48 0.46 0.41 1</diffuse></material></visual></link></model>
