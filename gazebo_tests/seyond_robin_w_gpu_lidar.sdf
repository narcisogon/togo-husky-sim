<?xml version="1.0" ?>
<sdf version="1.9">
  <world name="seyond_gpu_lidar_test">
    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <light name="sun" type="directional">
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.9 0.9 0.85 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.5 0.2 -1.0</direction>
      <cast_shadows>true</cast_shadows>
    </light>

    <model name="ground">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><plane><normal>0 0 1</normal><size>80 80</size></plane></geometry>
        </collision>
        <visual name="visual">
          <geometry><plane><normal>0 0 1</normal><size>80 80</size></plane></geometry>
          <material><ambient>0.35 0.35 0.35 1</ambient><diffuse>0.45 0.45 0.45 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="targets">
      <static>true</static>
      <pose>8 0 0 0 0 0</pose>
      <link name="box_1">
        <pose>0 0 1 0 0 0</pose>
        <collision name="collision"><geometry><box><size>1 4 2</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>1 4 2</size></box></geometry><material><diffuse>0.8 0.2 0.2 1</diffuse></material></visual>
      </link>
      <link name="box_2">
        <pose>5 4 1 0 0 0</pose>
        <collision name="collision"><geometry><box><size>1 1 2</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>1 1 2</size></box></geometry><material><diffuse>0.2 0.8 0.2 1</diffuse></material></visual>
      </link>
      <link name="box_3">
        <pose>5 -4 1 0 0 0</pose>
        <collision name="collision"><geometry><box><size>1 1 2</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>1 1 2</size></box></geometry><material><diffuse>0.2 0.2 0.8 1</diffuse></material></visual>
      </link>
    </model>

    <model name="seyond_robin_w_gpu_lidar_fixture">
      <static>true</static>
      <pose>0 0 1.2 0 0 0</pose>
      <link name="lidar_link">
        <sensor name="seyond_robin_w_sim" type="gpu_lidar">
          <always_on>true</always_on>
          <visualize>true</visualize>
          <update_rate>10</update_rate>
          <topic>/seyond_robin_w/scan</topic>
          <lidar>
            <scan>
              <horizontal>
                <samples>256</samples>
                <resolution>1</resolution>
                <min_angle>-1.0472</min_angle>
                <max_angle>1.0472</max_angle>
              </horizontal>
              <vertical>
                <samples>64</samples>
                <resolution>1</resolution>
                <min_angle>-0.6109</min_angle>
                <max_angle>0.6109</max_angle>
              </vertical>
            </scan>
            <range>
              <min>0.2</min>
              <max>80.0</max>
              <resolution>0.02</resolution>
            </range>
          </lidar>
        </sensor>
      </link>
    </model>
  </world>
</sdf>
