<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <!-- Sim-only IMU for TOGO/Husky SLAM testing.
       Clearpath's generated Phidgets entry creates the visual/link, but in
       Gazebo the IMU topic was not published. Use a unique sensor name to
       avoid colliding with any stock sensor named imu_0. -->
  <gazebo reference="imu_0_link">
    <sensor name="togo_imu_0" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <topic>/a300_0000/sensors/imu_0/data</topic>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>0.0002</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>0.0002</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>0.0002</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>0.01</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>0.01</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>0.01</stddev></noise></z>
        </linear_acceleration>
      </imu>
    </sensor>
  </gazebo>
</robot>
